# Copy to terraform.tfvars and set your values. Do not commit terraform.tfvars if it contains account-specific names.

aws_region            = "us-east-1"
state_bucket_name     = "YOUR-UNIQUE-TERRAFORM-STATE-BUCKET"   # e.g. mycompany-clienta-ai-terraform-state
state_lock_table_name = "terraform-state-lock"
