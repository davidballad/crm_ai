          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ messaging_product: 'whatsapp', recipient_type: 'individual', to: $('Extract & Filter').item.json.from_number.replace(/^\\\\+/,''), type: 'interactive', interactive: { type: 'button', body: { text: 'Added to cart!' }, action: { buttons: [ { type: 'reply', reply: { id: 'view_cart', title: 'View cart' } }, { type: 'reply', reply: { id: 'order', title: 'Keep browsing' } } ] } } }) }}"
      },
      "type": "n8n-nodes-base.httpRequest",
