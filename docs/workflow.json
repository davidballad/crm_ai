        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ messaging_product: 'whatsapp', recipient_type: 'individual', to: $('Extract & Filter').item.json.from_number.replace(/^\\+/,''), type: 'interactive', interactive: { type: 'button', body: { text: \"What would you like to do?\" }, action: { buttons: [ { type: 'reply', reply: { id: 'order', title: 'Order' } }, { type: 'reply', reply: { id: 'products', title: 'Products' } }, { type: 'reply', reply: { id: 'more_info', title: 'Something else' } } ] } } }) }}",
        "options": {}
