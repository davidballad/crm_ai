    {
      "parameters": {
        "jsCode": "const inv = $input.first().json;\nconst products = inv.products || inv || [];\nconst list = Array.isArray(products) ? products : [];\nconst text = list.length === 0 ? 'No products right now.' : list.map((p, i) => `${i+1}. ${p.name || p.product_name || 'Item'}${p.unit_cost != null ? ' — ' + p.unit_cost : ''}`).join('\\n');\nreturn [{ json: { output: text, product_count: list.length } }];",
        "options": {}
