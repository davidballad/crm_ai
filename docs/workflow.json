      "name": "Store Inbound",
      "notesInFlow": true,
      "notes": "POST /messages (save inbound)"
    },
    {
      "parameters": {
        "jsCode": "const bid = $('Extract & Filter').item.json.button_reply_id || '';\nlet route = 'show_options';\nlet product_id = null;\nif (bid === 'products') route = 'products';\nelse if (bid === 'order') route = 'order';\nelse if (bid === 'more_info') route = 'more_info';\nelse if (bid.startsWith('add_')) { route = 'add_to_cart'; product_id = bid.replace(/^add_/, ''); }\nelse if (bid === 'view_cart') route = 'view_cart';\nelse if (bid === 'checkout') route = 'checkout';\nreturn [{ json: { route, product_id } }];",
        "options": {}
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 300],
      "id": "b1c2d3e4-f5a6-4b7c-8d9e-0f1a2b3c4d5e",
      "name": "Route",
      "notesInFlow": true,
      "notes": "show_options | products | order | something_else | add_to_cart | view_cart | checkout"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "" }, "conditions": [{ "id": "r1", "leftValue": "={{ $json.route }}", "rightValue": "show_options", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Show 3 options" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "" }, "conditions": [{ "id": "r2", "leftValue": "={{ $json.route }}", "rightValue": "products", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Products" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "" }, "conditions": [{ "id": "r3", "leftValue": "={{ $json.route }}", "rightValue": "order", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Order" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "" }, "conditions": [{ "id": "r4", "leftValue": "={{ $json.route }}", "rightValue": "more_info", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Something else (AI)" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "" }, "conditions": [{ "id": "r5", "leftValue": "={{ $json.route }}", "rightValue": "add_to_cart", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Add to cart" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "" }, "conditions": [{ "id": "r6", "leftValue": "={{ $json.route }}", "rightValue": "view_cart", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "View cart" },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "" }, "conditions": [{ "id": "r7", "leftValue": "={{ $json.route }}", "rightValue": "checkout", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" }, "renameOutput": true, "outputKey": "Checkout" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1350, 300],
      "id": "c2d3e4f5-a6b7-4c8d-9e0f-1a2b3c4d5e6f",
