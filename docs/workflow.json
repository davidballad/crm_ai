      "id": "c8d9e0f1-a2b3-4c4d-5e6f-7a8b9c0d1e2f",
      "name": "Get Inventory for Order"
    },
    {
      "parameters": {
        "jsCode": "const ext = $('Extract & Filter').item.json;\nconst inv = $input.first().json;\nconst products = inv.products || inv || [];\nconst list = Array.isArray(products) ? products : [];\nconst to = (ext.from_number || '').replace(/^\\\\+/,'');\nconst placeholderImg = 'https://via.placeholder.com/300x300?text=Product';\nif (list.length >= 2) {\n  const cards = list.slice(0, 10).map((p, i) => ({\n    card_index: i,\n    type: 'cta_url',\n    header: { type: 'image', image: { link: p.image_url || placeholderImg } },\n    body: { text: (p.name || p.product_name || 'Item') + (p.unit_cost != null ? ' — ' + p.unit_cost : '') + (p.notes ? '\\n' + (p.notes || '').slice(0, 100) : '') },\n    action: { buttons: [ { type: 'quick_reply', quick_reply: { id: 'add_' + (p.id || p.product_id || String(i)), title: 'Add to cart' } } ] }\n  }));\n  const graphPayload = { messaging_product: 'whatsapp', recipient_type: 'individual', to, type: 'interactive', interactive: { type: 'carousel', body: { text: 'Choose a product and tap Add to cart:' }, action: { cards } } };\n  return [{ json: { graphPayload } }];\n}\nconst listText = list.length === 0 ? 'No products right now.' : list.map((p, i) => `${i+1}. ${p.name || p.product_name || 'Item'}${p.unit_cost != null ? ' — ' + p.unit_cost : ''}`).join('\\\\n');\nconst orderCTA = list.length > 0 ? '\\n\\nTap **Order** again to see products with Add to cart, or reply with item numbers (e.g. 1x2).' : '';\nreturn [{ json: { output: listText + orderCTA } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1850, 320],
      "id": "d9e0f1a2-b3c4-4d5e-6f7a-8b9c0d1e2f3a",
      "name": "Build Order Products Message"
