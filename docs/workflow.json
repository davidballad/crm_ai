    {
      "parameters": {
        "content": "**Order flow** (template, no chatbot)\nProducts as carousel (image + description + Add to cart). Tap Add to cart → API adds item → View cart / Keep browsing. View cart → Checkout → order created, payment link to follow.",
        "height": 120,
        "width": 320,
        "color": 6
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [1600, 320],
