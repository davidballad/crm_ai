    {
      "parameters": {
        "jsCode": "// ══════════════════════════════════════════════════════════════\n// CONFIGURATION — Set YOUR_API_BASE_URL and YOUR_SERVICE_API_KEY (or use n8n env vars)\n// ══════════════════════════════════════════════════════════════\nconst API_URL = \"YOUR_API_BASE_URL\";\nconst SERVICE_API_KEY = \"YOUR_SERVICE_API_KEY\";\n// ══════════════════════════════════════════════════════════════\n\nconst data = $input.first().json;\nconst body = data.body || data;\nconst entry = body.entry?.[0];\nconst changes = entry?.changes?.[0];\nconst value = changes?.value;\n\nif (!value?.messages || value.messages.length === 0) {\n  return [];\n}\n\nconst message = value.messages[0];\nconst metadata = value.metadata;\n\nreturn [{\n  json: {\n    api_url: API_URL,\n    service_api_key: SERVICE_API_KEY,\n    phone_number_id: metadata.phone_number_id,\n    display_phone_number: metadata.display_phone_number,\n    from_number: message.from,\n    message_id: message.id,\n    message_type: message.type,\n    message_text: message.type === 'text' ? message.text?.body : (message.interactive?.button_reply ? message.interactive.button_reply.title : `[${message.type}]`),\n    button_reply_id: message.interactive?.button_reply?.id || null,\n    contact_name: value.contacts?.[0]?.profile?.name || message.from,\n    timestamp: message.timestamp\n  }\n}];",
        "options": {}
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [350, 300],
      "id": "d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f8a",
