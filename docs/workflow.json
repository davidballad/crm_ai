          "parameters": [
            { "name": "customer_id", "value": "={{ $('Extract & Filter').item.json.from_number }}" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1600, 560],
      "id": "d5e6f7a8-b9c0-4d1e-2f3a-4b5c6d7e8f9a",
      "name": "Get Cart"
    },
    {
      "parameters": {
        "jsCode": "const cart = $input.first().json;\nconst items = cart.items || [];\nconst lines = items.map(i => `${i.product_name || 'Item'} x${i.quantity} — ${i.unit_price || '0'}`);\nconst total = items.reduce((s, i) => s + (parseFloat(i.unit_price || 0) * (i.quantity || 1)), 0);\nconst text = items.length === 0 ? 'Your cart is empty.' : lines.join('\\n') + '\\n———\\nTotal: ' + total.toFixed(2);\nreturn [{ json: { output: text, item_count: items.length } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1850, 560],
      "id": "e6f7a8b9-c0d1-4e2f-3a4b-5c6d7e8f9a0b",
      "name": "Format Cart"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $('Extract & Filter').item.json.phone_number_id }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer {{ $env.META_ACCESS_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ messaging_product: 'whatsapp', recipient_type: 'individual', to: $('Extract & Filter').item.json.from_number.replace(/^\\\\+/,''), type: 'interactive', interactive: { type: 'button', body: { text: $json.output }, action: { buttons: [ { type: 'reply', reply: { id: 'checkout', title: 'Checkout' } }, { type: 'reply', reply: { id: 'order', title: 'Keep browsing' } } ] } } }) }}"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2100, 560],
      "id": "f7a8b9c0-d1e2-4f3a-4b5c-6d7e8f9a0b1c",
      "name": "Send Cart Message"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Extract & Filter').item.json.api_url }}/cart/checkout",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Service-Key", "value": "={{ $('Extract & Filter').item.json.service_api_key }}" },
            { "name": "X-Tenant-Id", "value": "={{ $('Resolve Tenant').item.json.tenant_id }}" },
